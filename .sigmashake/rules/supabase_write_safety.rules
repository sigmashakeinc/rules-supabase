# supabase_write_safety.rules
# Technology: supabase | Capability: write

rule supabase-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "rpc("
  MESSAGE "Blocked an unsafe pattern in supabase. Use the recommended best practices for 2025/2026."
}

rule supabase-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "supabase.auth.signIn"
  MESSAGE "You are using an outdated API for supabase. Please upgrade to the newer API."
}
